# =============================================================================
# Resend — for contact form email delivery
# =============================================================================
# Sign up at https://resend.com (free tier: 100 emails/day, 3000/month)
# Verify your sending domain in the Resend dashboard
# Then create an API key

RESEND_API_KEY=re_your_api_key_here
CONTACT_FROM=hello@geodata.com.ng
CONTACT_TO=hello@geodata.com.ng

# =============================================================================
# Mapbox — for interactive property location maps
# =============================================================================
# Sign up at https://account.mapbox.com (free tier: 50,000 map loads/month)
# Copy your "Default public token" from the dashboard
# It looks like: pk.eyJ1Ij...
#
# IMPORTANT: This is exposed to the browser (NEXT_PUBLIC_*), so before
# launch, restrict it to your domains in the Mapbox dashboard:
#   - geodata.com.ng
#   - localhost:3000
# Otherwise anyone could steal and abuse it.

NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiX...

# =============================================================================
# Google Sheets — construction progress photo updates
# =============================================================================
# Get an API key at console.cloud.google.com → Enable "Google Sheets API"
# → Credentials → API Key → restrict to "Google Sheets API" only.
# Sheet ID is fixed — do not change it.

NEXT_PUBLIC_GOOGLE_SHEETS_ID=1Yw-NBGV6s--w63eIOA0qP6HmawAIzGjBePG5z26-NX4
NEXT_PUBLIC_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# =============================================================================
# To use this:
# =============================================================================
# 1. Copy this file to .env.local
# 2. Replace placeholder values with real ones
# 3. Restart `npm run dev`
# 4. For production: add the same vars in Vercel project settings
